+#include "dog_lifecycle/lifecycle_node.hpp"
+
+#include <functional>
+
+namespace dog_lifecycle
+{
+
+LifecycleNode::LifecycleNode()
+: rclcpp::Node("dog_lifecycle")
+{
+  math_detect_service_ = create_service<dog_interfaces::srv::MathDetect>(
+    "/dog/math_detect",
+    std::bind(
+      &LifecycleNode::handleMathDetect,
+      this,
+      std::placeholders::_1,
+      std::placeholders::_2));
+
+  RCLCPP_INFO(get_logger(), "dog_lifecycle skeleton node initialized");
+}
+
+void LifecycleNode::handleMathDetect(
+  const std::shared_ptr<dog_interfaces::srv::MathDetect::Request> request,
+  std::shared_ptr<dog_interfaces::srv::MathDetect::Response> response)
+{
+  (void)request;
+  response->success = false;
+  response->expression = "";
+  response->value = 0.0F;
+  response->message = "math detect skeleton not implemented";
+}
+
+}  // namespace dog_lifecycle
